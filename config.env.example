# ============================================================================
# URL Scraper API — configuration
# Copy to .env and adjust. All values shown are defaults.
# ============================================================================

# --- Server ---------------------------------------------------------------
PORT=3000
NODE_ENV=development
# Trust the first proxy hop (Nginx/LB) so req.ip and rate limiting are correct.
TRUST_PROXY=true
# Max request body size.
BODY_LIMIT=1mb
# How long to wait for in-flight requests to drain on shutdown (ms).
SHUTDOWN_TIMEOUT_MS=10000
# Serve the built web console (web/dist) from the API at /app.
# Build it first: cd web && npm install && npm run build
SERVE_UI=false

# --- Authentication (optional but STRONGLY recommended when public) -------
# Comma-separated API keys. When empty, the API is OPEN (no auth) — a warning is
# logged at startup. Clients send a key via the header below or `Authorization: Bearer <key>`.
API_KEYS=
API_KEY_HEADER=x-api-key

# --- Rate limiting --------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT=100                # general requests per window per key/IP
SCRAPER_RATE_LIMIT=20         # scrape requests per window per key/IP

# --- CORS -----------------------------------------------------------------
# Comma-separated allowlist. Leave unset for '*'.
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- Scraper (static fetch) ----------------------------------------------
SCRAPER_TIMEOUT=10000
MAX_CONTENT_LENGTH=2097152    # 2MB
SCRAPER_RETRIES=2             # retries on TRANSIENT errors only
SCRAPER_MAX_REDIRECTS=5
MAX_BATCH_URLS=5
# SCRAPER_USER_AGENT=MyBot/1.0 (+https://example.com/bot)
# DANGER: allow scraping private/loopback IPs. NEVER enable on a public instance.
ALLOW_PRIVATE_ADDRESSES=false

# --- JavaScript rendering (Playwright) -----------------------------------
# Requires: npm install playwright && npx playwright install chromium
RENDER_ENABLED=true
RENDER_TIMEOUT=30000
RENDER_WAIT_UNTIL=networkidle  # load | domcontentloaded | networkidle
RENDER_MAX_CONCURRENCY=2
# Screenshot output (POST /api/screenshot)
SCREENSHOT_FULL_PAGE=true
SCREENSHOT_TYPE=png            # png | jpeg
SCREENSHOT_QUALITY=80          # jpeg only
SCREENSHOT_VIEWPORT_WIDTH=1280
SCREENSHOT_VIEWPORT_HEIGHT=800
# PDF output (POST /api/pdf)
PDF_FORMAT=A4
PDF_LANDSCAPE=false
PDF_PRINT_BACKGROUND=true

# --- Request queue / throttling ------------------------------------------
QUEUE_ENABLED=true
SCRAPE_MAX_CONCURRENCY=10          # total in-flight scrapes
SCRAPE_PER_DOMAIN_CONCURRENCY=2    # in-flight per target domain (politeness)
SCRAPE_PER_DOMAIN_DELAY_MS=0       # min gap between requests to same domain
SCRAPE_QUEUE_MAX=100               # reject (503) beyond this many waiting
SCRAPE_QUEUE_TIMEOUT_MS=20000      # reject (503) if queued longer than this

# --- Usage analytics (GET /api/usage) ------------------------------------
ANALYTICS_ENABLED=true
ANALYTICS_TOP_DOMAINS=20
ANALYTICS_MAX_KEYS=100

# --- robots.txt -----------------------------------------------------------
RESPECT_ROBOTS=false          # set true for ethical/compliant scraping
ROBOTS_CACHE_TTL_MS=3600000

# --- Caching --------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL_MS=300000           # 5 minutes
CACHE_MAX_ITEMS=500

# --- Redis (optional: cluster-safe rate limiting + shared cache) ----------
# When set, rate limits and cache are shared across all instances.
# REDIS_URL=redis://localhost:6379

# --- Metrics & logging ----------------------------------------------------
METRICS_ENABLED=true          # exposes GET /metrics (Prometheus)
LOG_LEVEL=debug               # trace|debug|info|warn|error|fatal
LOG_PRETTY=true               # pretty logs in dev; set false for JSON in prod
