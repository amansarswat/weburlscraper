{
  "name": "url-scraper-api",
  "version": "2.3.0",
  "description": "Production-ready web scraping API: multiple extraction modes, optional JS rendering, SSRF-safe fetching, caching, rate limiting, metrics, and OpenAPI docs.",
  "main": "app.js",
  "types": "./sdk/index.d.ts",
  "exports": {
    ".": "./app.js",
    "./sdk": {
      "types": "./sdk/index.d.ts",
      "require": "./sdk/index.js",
      "default": "./sdk/index.js"
    }
  },
  "files": [
    "app.js",
    "server.js",
    "config/",
    "routes/",
    "middleware/",
    "security/",
    "utils/",
    "lib/",
    "docs/",
    "sdk/",
    "config.env.example",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "test:api": "node scripts/test-api.js",
    "setup": "node scripts/setup.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "browsers:install": "playwright install chromium",
    "docker:build": "docker build -t url-scraper-api .",
    "docker:run": "docker run -p 3000:3000 url-scraper-api",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop url-scraper-api",
    "pm2:restart": "pm2 restart url-scraper-api",
    "pm2:logs": "pm2 logs url-scraper-api"
  },
  "keywords": [
    "web-scraping",
    "url-scraper",
    "scraper-api",
    "cheerio",
    "playwright",
    "axios",
    "express",
    "ssrf",
    "api"
  ],
  "author": "URL Scraper API contributors",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.2.0",
    "ipaddr.js": "^2.4.0",
    "lru-cache": "^11.5.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "robots-parser": "^3.0.1",
    "swagger-ui-express": "^5.0.1"
  },
  "optionalDependencies": {
    "ioredis": "^5.11.1",
    "playwright": "^1.61.1",
    "rate-limit-redis": "^4.3.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "testTimeout": 15000,
    "collectCoverageFrom": [
      "utils/**/*.js",
      "security/**/*.js",
      "middleware/**/*.js",
      "lib/**/*.js",
      "routes/**/*.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
